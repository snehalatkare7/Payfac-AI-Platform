# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# NeonDB (PostgreSQL + pgvector)
NEONDB_CONNECTION_STRING=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/fraud_analysis?sslmode=require

# Redis (use redis://username:password@host:port/0 for Redis Labs)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Kafka (use SASL_SSL + credentials for Confluent Cloud)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_GROUP_ID=fraud-analysis-agents

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
